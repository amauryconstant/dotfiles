      "WebFetch(domain:wiki.hyprland.org)",
      "WebFetch(domain:docs.astronvim.com)",
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:wiki.archlinux.org)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch --list:*)",
      "Bash(git branch -v:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(git shortlog:*)",
      "Bash(git tag:*)",
      "Bash(git mv:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git rm:*)",
      "Bash(git worktree:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(git -C:*)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi status:*)",
      "Bash(chezmoi data:*)",
      "Bash(chezmoi cat:*)",
      "Bash(chezmoi execute-template:*)",
      "Bash(chezmoi managed:*)",
      "Bash(chezmoi unmanaged:*)",
      "Bash(chezmoi verify:*)",
      "Bash(chezmoi apply --dry-run:*)",
      "Bash(chezmoi source-path:*)",
      "Bash(chezmoi target-path:*)",
      "Bash(chezmoi merge:*)",
      "Bash(chezmoi merge-all:*)",
      "Bash(chezmoi_modify_manager --help-syntax:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(mktemp:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(tee:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(xargs:*)",
      "Bash(column:*)",
      "Bash(printf:*)",
      "Bash(test:*)",
      "Bash([:*)",
      "Bash(shellcheck:*)",
      "Bash(bash -n:*)",
      "Bash(zsh -n:*)",
      "Bash(jaq:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "Bash(mise run:*)",
      "Bash(mise tasks:*)",
      "Bash(hyprctl:*)",
      "Bash(journalctl:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl --user status:*)",
      "Bash(systemctl --user list-timers:*)",
      "Bash(systemctl --user show:*)",
      "Bash(systemctl --user cat:*)",
      "Bash(loginctl:*)",
      "Bash(paru -Q:*)",
      "Bash(paru -Si:*)",
      "Bash(paru -Ss:*)",
      "Bash(pacman -Q:*)",
      "Bash(pacman -Qdt:*)",
      "Bash(pacman -Si:*)",
      "Bash(pacman -Ss:*)",
      "Bash(flatpak list:*)",
      "Bash(flatpak info:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(fzf:*)",
      "Bash(swww query:*)",
      "Bash(darkman get:*)",
      "Bash(code:*)",
      "Bash(yamllint:*)",
      "Bash(stylua:*)",
      "Bash(lua-language-server:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [
      "Bash(chezmoi apply :*)",
      "Bash(chezmoi add --encrypt:*)",
      "Bash(chezmoi decrypt:*)",
      "Bash(chezmoi edit:*)",
      "Bash(rm -rf:*)",
      "Bash(git checkout:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(sudo:*)",
      "Bash(pacman -S:*)",
      "Bash(pacman -R:*)",
      "Bash(paru -S:*)",
      "Bash(paru -R:*)",
      "Bash(systemctl --user enable:*)",
      "Bash(systemctl --user disable:*)",
      "Bash(systemctl --user stop:*)",
      "Bash(systemctl --user restart:*)",
      "Bash(mkinitcpio:*)",
      "Bash(hyprpm:*)",
      "Bash(rage:*)",
      "Bash(age:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [[ -n \"$f\" && ( \"$f\" =~ private_dot_keys || \"$f\" =~ \\.age$ ) ]] && { echo \"Blocked: encrypted path — use chezmoi add --encrypt or chezmoi edit instead\" >&2; exit 2; } || exit 0",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [[ -n \"$f\" && \"$f\" =~ \\.sh$ && ! \"$f\" =~ \\.tmpl$ ]] && bash -n \"$f\" && shellcheck --severity=warning \"$f\" 2>/dev/null || true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [[ -n \"$f\" && \"$f\" =~ \\.sh\\.tmpl$ ]] && { tmp=$(mktemp --suffix=.sh); chezmoi execute-template < \"$f\" > \"$tmp\" 2>/dev/null && shellcheck --severity=warning \"$tmp\" 2>/dev/null && echo \"✓ Shell OK (rendered .sh.tmpl)\"; rm -f \"$tmp\"; } || true",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [[ -n \"$f\" && \"$f\" =~ \\.tmpl$ && ! \"$f\" =~ \\.chezmoitemplates ]] && { chezmoi execute-template < \"$f\" > /dev/null && echo \"✓ Template OK\" || { echo \"✗ Template syntax error:\" >&2; chezmoi execute-template < \"$f\" 2>&1 | head -5 >&2; }; } || true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [[ -n \"$f\" && \"$f\" =~ \\.yaml$ && ! \"$f\" =~ \\.tmpl$ ]] && command -v yamllint > /dev/null && yamllint -c .yamllint.yaml \"$f\" && echo \"✓ YAML OK\" || true",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "remember@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  }
}
