font-family = {{ .globals.terminalFont | quote }}
font-size = {{ if eq .chassisType "desktop" }}14{{ else }}12{{ end }}
theme = current
window-theme = ghostty
gtk-single-instance = false
keybind = shift+enter=text:\x1b\r

# Splits work natively (ctrl+shift+o/e create, ctrl+alt+arrows navigate,
# super+ctrl+shift+arrows resize, ctrl+shift+enter zoom). Only equalize is unbound.
keybind = ctrl+shift+equal=equalize_splits
