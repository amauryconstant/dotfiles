#!/usr/bin/env zsh
#
# zellij-layouts.zsh - Zellij session and layout helpers
#

# Auto-session: when navigating anywhere inside a project dir, rename current
# session to the project name or switch to the existing session with that name.
_zellij_project_session() {
  [[ -z $ZELLIJ ]] && return
  local projects_dir="{{ .globals.paths.projects }}"
  [[ $PWD != ${projects_dir}/* ]] && return
  # Extract top-level project name at any depth under projects_dir
  local rel="${PWD#${projects_dir}/}"
  local name="${${rel%%/*}//./_}"

  if zellij list-sessions 2>/dev/null | grep -qE "^${name}[[:space:]\[]"; then
    zellij action switch-to-session "$name" 2>/dev/null
  else
    zellij action rename-session "$name" 2>/dev/null
  fi
}

autoload -Uz add-zsh-hook
add-zsh-hook chpwd _zellij_project_session

# Internal: derive session name from a directory path
# Usage: _zdl_session_name <dir> [default-name]
_zdl_session_name() {
  local dir="$1" default="${2:-}"
  local projects_dir="{{ .globals.paths.projects }}"
  local name="${default:-$(basename "$dir")}"
  if [[ $dir == ${projects_dir}/* ]]; then
    local rel="${dir#${projects_dir}/}"
    name="${${rel%%/*}//./_}"
  fi
  echo "$name"
}

# Internal: attach to a named session if it exists, else create it
# Usage: _zdl_attach_or_create <session-name> [layout-file]
_zdl_attach_or_create() {
  local session_name="$1" layout="${2:-}"
  if zellij list-sessions 2>/dev/null | grep -qE "^${session_name}[[:space:]\[]"; then
    zellij attach "$session_name"
  elif [[ -n $layout ]]; then
    zellij --new-session-with-layout "$layout" -s "$session_name"
  else
    zellij -s "$session_name"
  fi
}

# Attach or create a session: uses project name when inside ~/Projects/*, else 'Work'
zj() {
  local name
  name="$(_zdl_session_name "$PWD" "Work")"
  _zdl_attach_or_create "$name"
}

# Coding layout: editor + terminal strip + AI pane (see layouts/coding.kdl)
# Usage: zdl [ai-cmd]  — optional command runs in the right 30% pane
zdl() {
  local ai_cmd="${*:-}"
  local layout tab_name
  tab_name="$(basename "$PWD")"
  local layout_src="${XDG_CONFIG_HOME:-$HOME/.config}/zellij/layouts/coding.kdl"

  if [[ -n $ai_cmd ]]; then
    local tmp_layout
    tmp_layout="$(mktemp /tmp/zellij-layout-XXXXXX.kdl)"
    awk -v cmd="$ai_cmd" '
      /pane size="30%" command="zsh"$/ {
        print "      pane size=\"30%\" command=\"zsh\" {"
        print "        args \"-c\" \"" cmd "\""
        print "      }"
        next
      }
      { print }
    ' "$layout_src" >| "$tmp_layout"
    layout="$tmp_layout"
  else
    layout="coding"
  fi

  if [[ -n $ZELLIJ ]]; then
    zellij action new-tab --layout "$layout" --tab-name "$tab_name"
  else
    local session_name
    session_name="$(_zdl_session_name "$PWD")"
    _zdl_attach_or_create "$session_name" "$layout"
  fi

  [[ $layout != "coding" ]] && rm -f "$layout"
}

# Swarm layout: N panes all running the same command
# Usage: zsl <pane-count> <command>
zsl() {
  [[ -z $1 || -z $2 ]] && { echo "Usage: zsl <pane-count> <command>"; return 1; }

  local count="$1" cmd="$2"
  local dir="$PWD"

  if [[ -n $ZELLIJ ]]; then
    zellij action send-keys "${cmd}" Enter

    local i
    for ((i = 1; i < count; i++)); do
      zellij action new-pane --cwd "$dir"
      zellij action send-keys "${cmd}" Enter
    done
  else
    # Build a layout with N panes all running the command
    local tmp_layout
    tmp_layout="$(mktemp /tmp/zellij-layout-XXXXXX.kdl)"
    {
      echo "layout {"
      echo "  pane split_direction=\"horizontal\" {"
      local i
      for ((i = 0; i < count; i++)); do
        echo "    pane cwd=\"$dir\" command=\"sh\" {"
        echo "      args \"-c\" \"$cmd\""
        echo "    }"
      done
      echo "  }"
      echo "}"
    } >| "$tmp_layout"
    local session_name
    session_name="$(_zdl_session_name "$dir")"
    _zdl_attach_or_create "$session_name" "$tmp_layout"
    rm -f "$tmp_layout"
  fi
}
