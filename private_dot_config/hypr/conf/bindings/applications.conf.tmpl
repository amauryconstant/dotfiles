# ============================================================================
# Application Launchers
# ============================================================================
# Quick access to frequently used applications.
# All applications use launch-or-focus pattern for single-instance behavior.
# ============================================================================

# Terminal: Super + Return
# Opens terminal in current working directory
bindd = SUPER, Return, Launch terminal in CWD, exec, {{ .globals.applications.terminal }} --working-directory=$(~/.local/lib/scripts/terminal/terminal-cwd)

# Application launcher: Super + D
# Wofi shows desktop applications from .desktop files
bindd = SUPER, D, Application launcher, exec, wofi --show drun

# File manager: Super + E (GUI)
# Uses launch-or-focus for single-instance behavior
bindd = SUPER, E, File manager, exec, ~/.local/lib/scripts/desktop/launch-or-focus thunar

# Web browser: Super + W
bindd = SUPER, W, Web browser, exec, firefox

# Neovim session picker: Super + O
# Fuzzy-find a project and open/attach its Zellij coding session
bindd = SUPER, O, Neovim session picker, exec, ghostty -e ~/.local/lib/scripts/terminal/zellij-sessionizer

# Neovim workspace picker (Ghostty-native, zellij-free trial): Super + Shift + O
# Same project picker, but opens a plain Neovim window (splits live in nvim)
bindd = SUPER SHIFT, O, Neovim workspace picker (Ghostty), exec, ghostty -e ~/.local/lib/scripts/terminal/ghostty-sessionizer

# Clipboard history: Super + C
# Shows clipboard history via wofi, select to copy back to clipboard
bindd = SUPER, C, Clipboard history, exec, cliphist list | wofi --dmenu | cliphist decode | wl-copy

# Delete from clipboard history: Super + Shift + C
bindd = SUPER SHIFT, C, Delete from clipboard history, exec, cliphist list | wofi --dmenu | cliphist delete
