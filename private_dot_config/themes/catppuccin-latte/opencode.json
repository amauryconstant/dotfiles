    "fg-subtle": "#6c6f85",
    "fg-contrast": "#dce0e8",
    "fg-keyword": "#8839ef",
    "fg-code-block": "#4c4f69",
    "accent-primary": "#1e66f5",
    "accent-info": "#179299",
    "accent-success": "#40a02b",
    "accent-warning": "#df8e1d",
    "accent-error": "#d20f39",
    "accent-highlight": "#8839ef",
    "accent-secondary": "#8839ef",
    "accent-tertiary": "#fe640b",
    "accent-modification": "#ea76cb",
    "accent-border": "#ccd0da",
    "accent-border-active": "#bcc0cc",
    "accent-border-subtle": "#acb0be",
    "accent-performance": "#e64553",
    "accent-media": "#8839ef",
    "accent-subtle": "#dc8a78",
    "accent-alternative": "#04a5e5",
    "accent-special": "#dd7878",
    "accent-urgent-secondary": "#fe640b",
    "accent-variable": "#d20f39",
    "accent-type": "#df8e1d",
    "accent-function-alt": "#1e66f5",
    "accent-markdown-link": "#04a5e5",
    "accent-markdown-code": "#40a02b",
