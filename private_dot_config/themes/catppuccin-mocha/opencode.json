    "accent-secondary": "#cba6f7",
    "accent-tertiary": "#fab387",
    "accent-modification": "#f5c2e7",
    "accent-border": "#313244",
    "accent-border-active": "#45475a",
    "accent-border-subtle": "#585b70",
    "accent-performance": "#eba0ac",
    "accent-media": "#cba6f7",
