  "theme": {
    "primary": "accent-primary",
    "secondary": "accent-secondary",
    "accent": "accent-modification",
    "error": "accent-error",
    "warning": "accent-warning",
    "success": "accent-success",
    "info": "accent-info",
    "text": "fg-primary",
    "textMuted": "fg-secondary",
    "background": "bg-primary",
    "backgroundPanel": "bg-secondary",
    "backgroundElement": "bg-tertiary",
    "border": "accent-border",
    "borderActive": "accent-border-active",
    "borderSubtle": "accent-border-subtle",
    "diffAdded": "accent-success",
    "diffRemoved": "accent-error",
    "diffContext": "fg-muted",
    "diffHunkHeader": "accent-tertiary",
    "diffHighlightAdded": "accent-success",
    "diffHighlightRemoved": "accent-error",
    "diffAddedBg": "bg-diff-added",
    "diffRemovedBg": "bg-diff-removed",
    "diffContextBg": "bg-diff-context",
    "diffLineNumber": "accent-border-active",
    "diffAddedLineNumberBg": "diff-line-number-bg-added",
    "diffRemovedLineNumberBg": "diff-line-number-bg-removed",
    "markdownText": "fg-primary",
    "markdownHeading": "accent-secondary",
    "markdownLink": "accent-primary",
    "markdownLinkText": "accent-alternative",
    "markdownCode": "accent-markdown-code",
    "markdownBlockQuote": "accent-warning",
    "markdownEmph": "accent-warning",
    "markdownStrong": "accent-tertiary",
    "markdownHorizontalRule": "fg-subtle",
    "markdownListItem": "accent-primary",
    "markdownListEnumeration": "accent-alternative",
    "markdownImage": "accent-primary",
    "markdownImageText": "accent-alternative",
    "markdownCodeBlock": "fg-code-block",
    "syntaxComment": "fg-muted",
    "syntaxKeyword": "fg-keyword",
    "syntaxFunction": "accent-function-alt",
    "syntaxVariable": "accent-variable",
    "syntaxString": "accent-success",
    "syntaxNumber": "accent-tertiary",
    "syntaxType": "accent-type",
    "syntaxOperator": "accent-syntax-operator",
    "syntaxPunctuation": "fg-primary"
