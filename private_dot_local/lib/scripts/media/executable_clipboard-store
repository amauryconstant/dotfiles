#!/bin/sh
# clipboard-store - Filter clipboard before storing in cliphist
# Layers: password manager windows → browser auth → terminal sessions → content scan

# --- Active window context ---
active_window=$(hyprctl activewindow -j 2>/dev/null) || active_window="{}"
window_class=$(printf '%s' "$active_window" | jaq -r '.class // ""' 2>/dev/null)
window_title=$(printf '%s' "$active_window" | jaq -r '.title // ""' 2>/dev/null)

# --- Layer 1: Window filtering ---

# Password managers
if printf '%s' "$window_class" | grep -qiE 'bitwarden|keepassxc|1password|lastpass|enpass|seahorse'; then exit 0; fi
if printf '%s' "$window_title" | grep -qiE 'bitwarden|vault|password|credential|master password'; then exit 0; fi

# Browsers on auth/login pages (both class AND title must match)
if printf '%s' "$window_class" | grep -qiE 'firefox|chromium|brave-browser|google-chrome|librewolf'; then
    if printf '%s' "$window_title" | grep -qiE 'sign.?in|log.?in|password|passphrase|credentials|unlock|authenticate|two.?factor|2fa|mfa|security key'; then
        exit 0
    fi
fi

# Terminals running sensitive commands (ssh, sudo, gpg, pass, age, gopass)
# Trailing spaces prevent matching 'passage', 'gopassword', etc.
if printf '%s' "$window_class" | grep -qiE 'ghostty|kitty|alacritty|foot|wezterm'; then
    if printf '%s' "$window_title" | grep -qiE 'ssh |sudo |su -|gpg |age |pass |gopass '; then
        exit 0
    fi
fi

# --- Layer 2: Content filtering ---

content=$(wl-paste --no-newline 2>/dev/null)
[ -z "$content" ] && exit 0

# Fast check: shell export lines (export VAR=value, e.g. from mise env)
if printf '%s' "$content" | grep -qE '^export [A-Za-z_][A-Za-z0-9_]*=.+'; then
    exit 0
fi

# Secret detection: gitleaks stdin scans for API keys, tokens, credentials, etc.
# Exit 0 = no secrets found; exit 1 = secrets found; exit 126 = unexpected error
if command -v gitleaks >/dev/null 2>&1; then
    if ! printf '%s' "$content" | gitleaks stdin --no-banner 2>/dev/null; then
        exit 0
    fi
fi

# --- Store in clipboard history ---
printf '%s' "$content" | cliphist store
