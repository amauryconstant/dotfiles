#!/usr/bin/env bash

# Script: set-wallpaper
# Purpose: Change wallpaper using awww
# Requirements: Arch Linux, awww

{{ includeTemplate "log_start" "Setting wallpaper" }}

set -euo pipefail

# Validate arguments
if [ $# -eq 0 ]; then
    {{ includeTemplate "log_error" "No wallpaper path provided" }}
    echo "Usage: set-wallpaper /path/to/wallpaper.jpg"
    echo ""
    echo "Examples:"
    echo "  set-wallpaper ~/Pictures/Wallpapers/sunset.jpg"
    echo "  set-wallpaper \$(find ~/Pictures/Wallpapers -type f | shuf -n1)  # Random"
    exit 1
fi

WALLPAPER_PATH="$1"
TRANSITION_TYPE="${2:-fade}"  # Default to fade, allow override
TRANSITION_DURATION="${3:-2}"  # Default to 2 seconds

# Validate wallpaper file exists
if [ ! -f "$WALLPAPER_PATH" ]; then
    {{ includeTemplate "log_error" "Wallpaper file not found: $WALLPAPER_PATH" }}
    exit 1
fi

# Check if awww daemon is running
if ! pgrep -x awww-daemon > /dev/null; then
    {{ includeTemplate "log_step" "Starting awww daemon" }}
    awww-daemon 2>/dev/null &
fi

# Wait for daemon to finish discovering outputs. On session/compositor
# restart, awww-daemon (whether started here or via Hyprland autostart)
# can be running before it has enumerated outputs, so "awww img" fails
# with "none of the requested outputs are valid" if called too early.
READY_ATTEMPTS=10
until awww query 2>/dev/null | grep -q .; do
    READY_ATTEMPTS=$((READY_ATTEMPTS - 1))
    if [ "$READY_ATTEMPTS" -le 0 ]; then
        {{ includeTemplate "log_error" "awww daemon did not report any outputs in time" }}
        exit 1
    fi
    sleep 0.5
done

{{ includeTemplate "log_step" "Setting wallpaper with awww" }}
awww img "$WALLPAPER_PATH" \
    --transition-type "$TRANSITION_TYPE" \
    --transition-duration "$TRANSITION_DURATION"

# Call user hook
if [ -f "$HOME/.local/lib/scripts/core/hook-runner" ]; then
    "$HOME/.local/lib/scripts/core/hook-runner" wallpaper-change "$WALLPAPER_PATH" 2>/dev/null || true
fi

{{ includeTemplate "log_complete" "Wallpaper updated successfully" }}
