#!/usr/bin/env sh

# Script: menu-install.sh
# Purpose: Install menu (Package installation and setup)
# Requirements: Arch Linux, wofi

# Source helpers
. "$SCRIPTS_DIR/user-interface/menu-helpers.sh"

# Menu options
OPTIONS="箚걤 Back|箚룛 Install Package|箚슜 AI Models (llama.cpp)|箚쇁 Development Tools|箚삉 Code Editors"

CHOICE=$(show_menu "Install" "$OPTIONS")

case "$CHOICE" in
    "箚걤 Back")
        "$SCRIPTS_DIR/user-interface/system-menu.sh"
        ;;
    "箚룛 Install Package")
        # Interactive package installation
        if [ -f "$SCRIPTS_DIR/system/package-manager.sh" ]; then
            {{ .globals.applications.terminal }} -e "$SCRIPTS_DIR/system/package-manager.sh" install
        else
            # Fallback to simple search and install
            PACKAGE=$(echo "" | wofi --dmenu --prompt "Package name to install")
            if [ -n "$PACKAGE" ]; then
                if confirm "Install package: $PACKAGE?"; then
                    {{ .globals.applications.terminal }} -e sh -c "paru -S $PACKAGE; read -p 'Press Enter to continue...'"
                fi
            fi
        fi
        ;;
    "箚슜 AI Models (llama.cpp)")
        # llama.cpp model management
        MODELS_DIR="{{ .chezmoi.homeDir }}/.local/share/models"

        if command -v llama-server >/dev/null 2>&1; then
            MODEL_OPTIONS="箚걤 Back|箚돃 List Models|箚떅 Server Status"
            MODEL_CHOICE=$(show_menu "llama.cpp" "$MODEL_OPTIONS")

            case "$MODEL_CHOICE" in
                "箚걤 Back")
                    "$SCRIPTS_DIR/user-interface/menu-install.sh"
                    ;;
                "箚돃 List Models")
                    if [ -d "$MODELS_DIR" ]; then
                        GGUF_FILES=$(find "$MODELS_DIR" -maxdepth 1 -name "*.gguf" -type f 2>/dev/null | wc -l)
                        if [ "$GGUF_FILES" -gt 0 ]; then
                            {{ .globals.applications.terminal }} -e sh -c "ls -lh $MODELS_DIR/*.gguf 2>/dev/null; read -p 'Press Enter to continue...'"
                        else
                            notify "箚슜 llama.cpp" "No GGUF files in $MODELS_DIR"
                        fi
                    else
                        notify "箚슜 llama.cpp" "Models directory not found"
                    fi
                    ;;
                "箚떅 Server Status")
                    if systemctl --user is-active --quiet llama-server.service; then
                        STATUS="Running on 127.0.0.1:8080"
                    elif [ -f "{{ .chezmoi.homeDir }}/.config/llama-server/env" ]; then
                        STATUS="Configured (not running)"
                    else
                        STATUS="Not configured - no ~/.config/llama-server/env"
                    fi
                    notify "箚떅 llama-server" "$STATUS"
                    ;;
            esac
        else
            notify "箚슜 llama.cpp" "llama-server not installed\nInstall with: paru -S llama-cpp-cuda"
        fi
        ;;
    "箚쇁 Development Tools")
        # Common dev tool installation
        DEV_OPTIONS="箚걤 Back|箚〃 Docker|茶삒 Rust Toolchain|箚뙛 Python (mise)|箚럺 Node.js (mise)|箚윋 Go (mise)"
        DEV_CHOICE=$(show_menu "Development Tools" "$DEV_OPTIONS")

        case "$DEV_CHOICE" in
            "箚걤 Back")
                "$SCRIPTS_DIR/user-interface/menu-install.sh"
                ;;
            "箚〃 Docker")
                if confirm "Install Docker?"; then
                    {{ .globals.applications.terminal }} -e sh -c "paru -S docker docker-compose docker-buildx; sudo systemctl enable --now docker; sudo usermod -aG docker $USER; read -p 'Press Enter to continue...'"
                fi
                ;;
            "茶삒 Rust Toolchain")
                {{ .globals.applications.terminal }} -e sh -c "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh; read -p 'Press Enter to continue...'"
                ;;
            "箚뙛 Python (mise)")
                VERSION=$(echo "3.12\n3.11\n3.10" | wofi --dmenu --prompt "Python version")
                if [ -n "$VERSION" ]; then
                    {{ .globals.applications.terminal }} -e sh -c "mise use --global python@$VERSION; read -p 'Press Enter to continue...'"
                fi
                ;;
            "箚럺 Node.js (mise)")
                VERSION=$(echo "lts\n20\n18" | wofi --dmenu --prompt "Node.js version")
                if [ -n "$VERSION" ]; then
                    {{ .globals.applications.terminal }} -e sh -c "mise use --global node@$VERSION; read -p 'Press Enter to continue...'"
                fi
                ;;
            "箚윋 Go (mise)")
                {{ .globals.applications.terminal }} -e sh -c "mise use --global go@latest; read -p 'Press Enter to continue...'"
                ;;
        esac
        ;;
    "箚삉 Code Editors")
        # Editor installation
        EDITOR_OPTIONS="箚걤 Back|箚쯂 VSCode|箚쯂 VSCodium|箚빓 Neovim Config|茶뱿 Helix"
        EDITOR_CHOICE=$(show_menu "Code Editors" "$EDITOR_OPTIONS")

        case "$EDITOR_CHOICE" in
            "箚걤 Back")
                "$SCRIPTS_DIR/user-interface/menu-install.sh"
                ;;
            "箚쯂 VSCode")
                if confirm "Install Visual Studio Code?"; then
                    {{ .globals.applications.terminal }} -e sh -c "paru -S code; read -p 'Press Enter to continue...'"
                fi
                ;;
            "箚쯂 VSCodium")
                if confirm "Install VSCodium (FOSS VSCode)?"; then
                    {{ .globals.applications.terminal }} -e sh -c "paru -S vscodium-bin; read -p 'Press Enter to continue...'"
                fi
                ;;
            "箚빓 Neovim Config")
                notify "箚빓 Neovim" "Neovim already installed\nConfigure via dotfiles or use kickstart.nvim"
                ;;
            "茶뱿 Helix")
                if confirm "Install Helix editor?"; then
                    {{ .globals.applications.terminal }} -e sh -c "paru -S helix; read -p 'Press Enter to continue...'"
                fi
                ;;
        esac
        ;;
esac
