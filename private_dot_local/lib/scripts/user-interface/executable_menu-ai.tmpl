#!/usr/bin/env sh

# Script: menu-ai
# Purpose: AI tools submenu
# Requirements: Arch Linux, wofi

. "$SCRIPTS_DIR/user-interface/menu-helpers.sh"

OPTIONS="󰁍 Back|󱚣 opencode|󱙺 claude-code|󰋼 llama-server Status"

CHOICE=$(show_menu "AI" "$OPTIONS")

case "$CHOICE" in
    "󰁍 Back")
        "$SCRIPTS_DIR/user-interface/system-menu"
        ;;
    "󱚣 opencode")
        {{ .globals.applications.terminal }} --class ai-scratchpad -e opencode
        ;;
    "󱙺 claude-code")
        {{ .globals.applications.terminal }} --class ai-scratchpad -e claude
        ;;
    "󰋼 llama-server Status")
        {{ .globals.applications.terminal }} --class ai-scratchpad -e sh -c "systemctl --user status llama-server.service; echo ''; read -p 'Press Enter to continue...'"
        ;;
esac
