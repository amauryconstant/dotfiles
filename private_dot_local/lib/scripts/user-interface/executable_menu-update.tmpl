#!/usr/bin/env sh

# Script: menu-update.sh
# Purpose: Update menu (System and configuration updates)
# Requirements: Arch Linux, wofi

# Source helpers
. "$SCRIPTS_DIR/user-interface/menu-helpers.sh"

# Menu options
OPTIONS="ůįĀć Back|ůįöį Full System Update|ůįĎď Config Refresh (chezmoi)|ůį¶Ė Package Sync Only|ůį£ź Firmware Update|ůįÖź Sync Time|ůįíč Update Mirrorlist"

CHOICE=$(show_menu "Update" "$OPTIONS")

case "$CHOICE" in
    "ůįĀć Back")
        "$SCRIPTS_DIR/user-interface/system-menu.sh"
        ;;
    "ůįöį Full System Update")
        # Runs: package-manager update + firmware + git + cleanup
        if command -v topgrade >/dev/null 2>&1; then
            {{ .globals.applications.terminal }} -e topgrade
        else
            if confirm "Topgrade not installed. Install it?"; then
                {{ .globals.applications.terminal }} -e sh -c "paru -S topgrade; topgrade; read -p 'Press Enter to continue...'"
            fi
        fi
        ;;
    "ůįĎď Config Refresh (chezmoi)")
        if confirm "Pull and apply latest dotfiles?"; then
            {{ .globals.applications.terminal }} -e sh -c "chezmoi update; read -p 'Press Enter to continue...'"
            notify "ůįĎď Chezmoi" "Dotfiles updated"
        fi
        ;;
    "ůį¶Ė Package Sync Only")
        # Only sync to packages.yaml (no updates to other packages)
        {{ .globals.applications.terminal }} -e sh -c "{{ .chezmoi.homeDir }}/.local/bin/package-manager sync --prune; read -p 'Press Enter to continue...'"
        ;;
    "ůį£ź Firmware Update")
        if command -v fwupdmgr >/dev/null 2>&1; then
            FW_OPTIONS="ůįĀć Back|ůįčó Check for Updates|ůįáö Download Updates|ůįĀĮ Install Updates|ůįĺį Show Devices"
            FW_CHOICE=$(show_menu "Firmware Update" "$FW_OPTIONS")

            case "$FW_CHOICE" in
                "ůįĀć Back")
                    "$SCRIPTS_DIR/user-interface/menu-update.sh"
                    ;;
                "ůįčó Check for Updates")
                    {{ .globals.applications.terminal }} -e sh -c "fwupdmgr refresh; fwupdmgr get-updates; read -p 'Press Enter to continue...'"
                    ;;
                "ůįáö Download Updates")
                    {{ .globals.applications.terminal }} -e sh -c "fwupdmgr refresh; fwupdmgr download; read -p 'Press Enter to continue...'"
                    ;;
                "ůįĀĮ Install Updates")
                    if confirm "Install firmware updates?\n(May require reboot)"; then
                        {{ .globals.applications.terminal }} -e sh -c "fwupdmgr update; read -p 'Press Enter to continue...'"
                    fi
                    ;;
                "ůįĺį Show Devices")
                    {{ .globals.applications.terminal }} -e sh -c "fwupdmgr get-devices; read -p 'Press Enter to continue...'"
                    ;;
            esac
        else
            notify "ůį£ź Firmware" "fwupd not installed\nInstall with: paru -S fwupd"
        fi
        ;;
    "ůįÖź Sync Time")
        if confirm "Sync system time with NTP?"; then
            {{ .globals.applications.terminal }} -e sh -c "sudo timedatectl set-ntp true; sudo timedatectl status; read -p 'Press Enter to continue...'"
            notify "ůįÖź Time" "System time synchronized"
        fi
        ;;
    "ůįíč Update Mirrorlist")
        if command -v rate-mirrors >/dev/null 2>&1; then
            if confirm "Update Arch mirrorlist?\n(Finds fastest mirrors)"; then
                {{ .globals.applications.terminal }} -e sh -c "rate-mirrors --save=/tmp/mirrorlist arch && sudo cp /tmp/mirrorlist /etc/pacman.d/mirrorlist; read -p 'Press Enter to continue...'"
                notify "ůįíč Mirrorlist" "Updated with fastest mirrors"
            fi
        else
            notify "ůįíč Mirrorlist" "rate-mirrors not installed\nInstall with: paru -S rate-mirrors"
        fi
        ;;
esac
