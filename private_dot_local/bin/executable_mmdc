#!/usr/bin/env bash

# Script: mmdc
# Purpose: Translate mmdc CLI flags to mmdr-compatible flags
# Requirements: mmdr (mmdr-bin AUR package)

input=""
output=""
width=""
height=""

while [ $# -gt 0 ]; do
    case "$1" in
        -i)       input="$2";  shift 2 ;;
        -o)       output="$2"; shift 2 ;;
        --width)  width="$2";  shift 2 ;;
        --height) height="$2"; shift 2 ;;
        -b|-t|-s) shift 2 ;;
        *)        shift ;;
    esac
done

if [ -z "$input" ] || [ -z "$output" ]; then
    echo "mmdc: -i and -o are required" >&2
    exit 1
fi

args=(-i "$input" -o "$output")
[ -n "$width" ]  && args+=(--width "$width")
[ -n "$height" ] && args+=(--height "$height")

exec mmdr "${args[@]}"
