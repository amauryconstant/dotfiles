{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint/v0.40.0/schema/markdownlint-config-schema.json",
  "default": true,
  "MD003": { "style": "atx" },
  "MD004": { "style": "dash" },
  "MD007": { "indent": 2 },
  "MD013": false,
  "MD024": { "siblings_only": true},
  "MD033": false,
  "MD046": { "style": "fenced" },
  "MD060": { "aligned_delimiter": true, "style": "aligned"}
}
