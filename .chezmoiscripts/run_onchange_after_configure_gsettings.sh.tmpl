#!/usr/bin/env bash

# Script: run_onchange_after_configure_gsettings.sh
# Purpose: Configure GSettings font settings for Wayland (used by Firefox and GTK apps via XDG portal)
# Requirements: Arch Linux, gsettings

# Hash: {{ list .globals.guiFont .globals.terminalFont (.gsettings | toJson) | join " " | sha256sum }}

{{ includeTemplate "log_start" "Configuring GSettings font settings..." }}

set -euo pipefail

if ! command -v gsettings >/dev/null 2>&1; then
    {{ includeTemplate "log_skip" "gsettings not available, skipping" }}
    exit 0
fi

{{ includeTemplate "log_step" "Setting GUI font (sans-serif)..." }}
gsettings set {{ .gsettings.font_schema }} font-name '{{ .globals.guiFont }} {{ .gsettings.sizes.gui }}'

{{ includeTemplate "log_step" "Setting monospace font (terminal)..." }}
gsettings set {{ .gsettings.font_schema }} monospace-font-name '{{ .globals.terminalFont }} {{ .gsettings.sizes.mono }}'

{{ includeTemplate "log_step" "Setting document font..." }}
gsettings set {{ .gsettings.font_schema }} document-font-name '{{ .globals.guiFont }} {{ .gsettings.sizes.document }}'

{{ range .gsettings.extra_settings }}
{{ includeTemplate "log_step" (printf "Setting %s %s..." .schema .key) }}
gsettings set {{ .schema }} {{ .key }} '{{ .value }}'
{{ end }}
{{ includeTemplate "log_complete" "GSettings fonts configured (Firefox and GTK apps will use Inter as GUI font)" }}
