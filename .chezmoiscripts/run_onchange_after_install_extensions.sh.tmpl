#!/usr/bin/env sh

# Script: run_onchange_after_install_extensions.sh.tmpl
# Purpose: Install Firefox policies for Arch Linux work environment
# Requirements: Arch Linux, firefox

# Hash: {{ .firefox_policies | toJson | sha256sum }}

{{ includeTemplate "log_start" "Installing Firefox policies..." }}

# Install Firefox policies
{{ includeTemplate "log_step" "Installing Firefox policies..." }}
sudo mkdir -p /usr/lib/firefox/distribution
sudo tee /usr/lib/firefox/distribution/policies.json > /dev/null << 'FIREFOX_POLICIES_EOF'
{{ .firefox_policies | toPrettyJson }}
FIREFOX_POLICIES_EOF
sudo chmod 644 /usr/lib/firefox/distribution/policies.json
{{ includeTemplate "log_success" "Firefox policies installed" }}

{{ includeTemplate "log_complete" "Firefox policy installation completed" }}
