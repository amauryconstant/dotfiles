#!/usr/bin/env bash

# Script: run_onchange_after_install_ai_models.sh.tmpl
# Purpose: Download GGUF models and configure llama-server
# Requirements: Arch Linux, llama-cpp-cuda

# Hash: {{ .ai.models | toJson | sha256sum }}

{{ includeTemplate "log_start" "Setting up local AI stack..." }}

set -euo pipefail

MODELS_DIR="{{ .chezmoi.homeDir }}/.local/share/models"

# --- Models directory ---
{{ includeTemplate "log_step" "Creating models directory..." }}
mkdir -p "$MODELS_DIR"

{{- if .ai.models }}
LLAMA_ENV="{{ .chezmoi.homeDir }}/.config/llama-server/env"

# --- llama-server check ---
if ! command -v llama-server >/dev/null 2>&1; then
    {{ includeTemplate "log_warning" "llama-server not found — skipping model download" }}
    {{ includeTemplate "log_info" "Install with: paru -S llama-cpp-cuda" }}
    exit 0
fi

# --- Download models ---
{{ includeTemplate "log_step" "Checking models..." }}
{{- range .ai.models }}
MODEL_PATH="$MODELS_DIR/{{ .file }}"
if [[ ! -f "$MODEL_PATH" ]]; then
    {{ includeTemplate "log_step" (printf "Downloading %s (this will take a while)..." .name) }}
    wget -c --show-progress \
        "{{ .url }}" \
        -O "${MODEL_PATH}.part"
    mv "${MODEL_PATH}.part" "$MODEL_PATH"
    {{ includeTemplate "log_success" (printf "Downloaded %s" .name) }}
else
    {{ includeTemplate "log_skip" (printf "%s already present" .name) }}
fi
{{- end }}

# --- llama-server env (first model is the default) ---
if [[ ! -f "$LLAMA_ENV" ]]; then
    {{ includeTemplate "log_step" "Creating llama-server env..." }}
    mkdir -p "$(dirname "$LLAMA_ENV")"
    printf 'MODEL_FILE=%s\nN_GPU_LAYERS=%d\n' \
        "{{ (index .ai.models 0).file }}" \
        "{{ .ai.server.n_gpu_layers }}" > "$LLAMA_ENV"
    {{ includeTemplate "log_success" "Created ~/.config/llama-server/env" }}
    {{ includeTemplate "log_info" "Start with: systemctl --user start llama-server.service" }}
else
    {{ includeTemplate "log_skip" "~/.config/llama-server/env already exists" }}
fi
{{- else }}
{{ includeTemplate "log_warning" "No models configured in ai.yaml — nothing to download" }}
{{- end }}

{{ includeTemplate "log_complete" "Local AI stack ready" }}
