#!/usr/bin/env bash

# Script: run_onchange_after_install_ai_models.sh.tmpl
# Purpose: Set up llama.cpp models directory and configuration
# Requirements: Arch Linux, llama-cpp-cuda

# Hash: {{ .ai.models | toJson | sha256sum }}

{{ includeTemplate "log_start" "Setting up llama.cpp models..." }}

set -euo pipefail

MODELS_DIR="{{ .chezmoi.homeDir }}/.local/share/models"

# Create models directory if it doesn't exist
{{ includeTemplate "log_step" "Creating models directory..." }}
mkdir -p "$MODELS_DIR"
{{ includeTemplate "log_success" "Models directory ready: $MODELS_DIR" }}

# Check if llama-server is available
if ! command -v llama-server >/dev/null 2>&1; then
    {{ includeTemplate "log_warning" "llama-server not found" }}
    {{ includeTemplate "log_info" "Install with: paru -S llama-cpp-cuda" }}
    exit 0
fi

{{ includeTemplate "log_step" "llama-server is installed" }}

# Current configuration
{{ includeTemplate "log_info" "Server configuration:" }}
{{ includeTemplate "log_info" "  Host: {{ .ai.server.host }}" }}
{{ includeTemplate "log_info" "  Port: {{ .ai.server.port }}" }}
{{ includeTemplate "log_info" "  GPU layers: {{ .ai.server.n_gpu_layers }}" }}

# Check if models are configured
{{- if .ai.models }}
{{ includeTemplate "log_info" "Configured models:" }}
{{- range .ai.models }}
{{ includeTemplate "log_info" "  - {{ .name }}" }}
{{- end }}
{{- else }}
{{ includeTemplate "log_info" "No models configured yet" }}
{{ includeTemplate "log_info" "To add a model, create: ~/.config/llama-server/env" }}
{{ includeTemplate "log_info" "  MODEL_FILE=your-model.gguf" }}
{{ includeTemplate "log_info" "  N_GPU_LAYERS=99" }}
{{- end }}

{{ includeTemplate "log_complete" "llama.cpp setup complete" }}