#!/usr/bin/env bash

# Script: run_once_after_010_setup_optional_services.sh.tmpl
# Purpose: Consolidated optional services setup (Voxtype STT, Home Backup, Kanata)
# Requirements: Arch Linux, optional packages (voxtype-bin, restic, kanata-bin)
# Execution: Runs AFTER file application to configure optional services
#
# This script consolidates:
# - Voxtype speech-to-text with Parakeet + CUDA
# - Restic home backup repository initialization
# - Kanata keyboard remapper (laptop only — Workman layout)
#
# Benefits of consolidation:
# - Single pass for optional service configuration
# - Consistent pattern: check package → configure → enable service
# - Graceful handling of missing packages (skip vs error)

{{ includeTemplate "log_start" "Setting up optional services (Voxtype, Home Backup, Kanata)..." }}

set -euo pipefail

SERVICES_CONFIGURED=false

# ============================================================================
# SECTION 1: VOXTYPE SPEECH-TO-TEXT
# ============================================================================

echo ""
echo "════════════════════════════════════════════════════════════════"
echo "  SECTION 1: Voxtype Speech-to-Text"
echo "════════════════════════════════════════════════════════════════"
echo ""

VOXTYPE_CONFIGURED=false

{{ if .features.voxtype.enabled }}
if ! command -v voxtype >/dev/null 2>&1; then
    {{ includeTemplate "log_skip" "Voxtype not installed" }}
else
    # Input group (required for built-in hotkey)
    {{- $username := .chezmoi.username }}
    {{ includeTemplate "log_step" "Checking input group membership..." }}

    if id -nG {{ $username }} | grep -qw input; then
        {{ includeTemplate "log_skip" "User already in input group" }}
    else
        sudo usermod -aG input {{ $username }}
        {{ includeTemplate "log_success" "User added to input group" }}
        {{ includeTemplate "log_warning" "Logout/login required for group change" }}
    fi

    # Enable ONNX Engine (auto-selects CUDA when available)
    {{ includeTemplate "log_step" "Enabling ONNX engine..." }}

    CURRENT_SYMLINK=$(readlink /usr/bin/voxtype)

    case "$CURRENT_SYMLINK" in
        */voxtype-onnx-cuda|*/voxtype-onnx-rocm|*/voxtype-onnx-avx2|*/voxtype-onnx-avx512)
            {{ includeTemplate "log_skip" "ONNX engine already enabled" }}
            ;;
        *)
            sudo voxtype setup onnx --enable
            {{ includeTemplate "log_success" "ONNX engine enabled" }}
            ;;
    esac

    # Download STT Models
    VOXTYPE_DATA="$HOME/.local/share/voxtype"

    # Parakeet (primary — fast English, ONNX CUDA)
    {{ includeTemplate "log_step" "Checking for Parakeet model..." }}
    if find "$VOXTYPE_DATA/models" -name "*.onnx" -maxdepth 2 2>/dev/null | grep -qi parakeet; then
        {{ includeTemplate "log_skip" "Parakeet model already downloaded" }}
    else
        {{ includeTemplate "log_step" "Downloading Parakeet model (~600 MB)..." }}
        voxtype setup --download --model parakeet-tdt-0.6b-v3 --no-post-install
        {{ includeTemplate "log_success" "Parakeet model downloaded" }}
    fi

    # Moonshine (secondary English engine, lower VRAM)
    {{ includeTemplate "log_step" "Checking for Moonshine model..." }}
    if find "$VOXTYPE_DATA/models" -name "*.onnx" -maxdepth 2 2>/dev/null | grep -qi moonshine; then
        {{ includeTemplate "log_skip" "Moonshine model already downloaded" }}
    else
        {{ includeTemplate "log_step" "Downloading Moonshine base model (~237 MB)..." }}
        voxtype setup --download --model moonshine-base --no-post-install
        {{ includeTemplate "log_success" "Moonshine model downloaded" }}
    fi

    # Whisper large-v3-turbo (multilingual fallback)
    {{ includeTemplate "log_step" "Checking for Whisper large-v3-turbo model..." }}
    if find "$VOXTYPE_DATA/models" -name "ggml-large-v3-turbo.bin" -maxdepth 1 2>/dev/null | grep -q .; then
        {{ includeTemplate "log_skip" "Whisper large-v3-turbo already downloaded" }}
    else
        {{ includeTemplate "log_step" "Downloading Whisper large-v3-turbo model (~1.5 GB)..." }}
        voxtype setup --download --model large-v3-turbo --no-post-install
        {{ includeTemplate "log_success" "Whisper large-v3-turbo downloaded" }}
    fi

    # Enable Systemd User Service
    {{ includeTemplate "log_step" "Enabling voxtype systemd service..." }}

    if systemctl --user is-enabled --quiet voxtype; then
        {{ includeTemplate "log_skip" "Service already enabled" }}
    else
        systemctl --user enable --now voxtype
        {{ includeTemplate "log_success" "Voxtype service enabled" }}
    fi

    if systemctl --user is-active --quiet voxtype; then
        {{ includeTemplate "log_success" "Voxtype service running" }}
    else
        {{ includeTemplate "log_warning" "Voxtype service not active" }}
        {{ includeTemplate "log_info" "Check status: systemctl --user status voxtype" }}
    fi

    VOXTYPE_CONFIGURED=true
    SERVICES_CONFIGURED=true
fi
{{ else }}
{{ includeTemplate "log_skip" "Voxtype setup disabled in features.yaml" }}
{{ end }}

# ============================================================================
# SECTION 2: RESTIC HOME BACKUP
# ============================================================================

echo ""
echo "════════════════════════════════════════════════════════════════"
echo "  SECTION 2: Home Backup Repository"
echo "════════════════════════════════════════════════════════════════"
echo ""

BACKUP_CONFIGURED=false
PASSWORD_FILE="{{ .chezmoi.homeDir }}/.local/share/backups/.restic-password"
REPO="{{ .chezmoi.homeDir }}/.local/share/backups/home-backup"

{{ if .features.restic.enabled }}
if ! command -v restic >/dev/null 2>&1; then
    {{ includeTemplate "log_skip" "restic not installed — skipping home backup init" }}
    {{ includeTemplate "log_info" "To enable: add 'restic' to packages.yaml and run 'chezmoi apply'" }}
else
    {{ includeTemplate "log_success" "restic is installed" }}

    {{ includeTemplate "log_step" "Check if password file is available..." }}

    if [[ ! -f "$PASSWORD_FILE" ]]; then
        {{ includeTemplate "log_skip" "Password file not found at $PASSWORD_FILE — skipping init" }}
        {{ includeTemplate "log_info" "The encrypted password was not decrypted (missing age key?)" }}
        {{ includeTemplate "log_info" "To initialize manually: home-backup init" }}
    else
        {{ includeTemplate "log_success" "Password file found" }}

        {{ includeTemplate "log_step" "Check if repository already initialized..." }}

        if [[ -d "$REPO" ]]; then
            {{ includeTemplate "log_skip" "Repository already exists at $REPO — skipping init" }}
        else
            {{ includeTemplate "log_step" "Initializing home backup repository..." }}

            home-backup init --non-interactive

            {{ includeTemplate "log_success" "Repository initialized at $REPO" }}
            BACKUP_CONFIGURED=true
            SERVICES_CONFIGURED=true
        fi
    fi
fi
{{ else }}
{{ includeTemplate "log_skip" "Restic setup disabled in features.yaml" }}
{{ end }}

# ============================================================================
# SECTION 3: KANATA KEYBOARD REMAPPER (laptop only)
# ============================================================================

echo ""
echo "════════════════════════════════════════════════════════════════"
echo "  SECTION 3: Kanata Keyboard Remapper"
echo "════════════════════════════════════════════════════════════════"
echo ""

KANATA_CONFIGURED=false

{{- $username := .chezmoi.username }}
{{ if and .features.kanata.enabled (eq .chassisType "laptop") }}
if ! command -v kanata >/dev/null 2>&1; then
    {{ includeTemplate "log_skip" "Kanata not installed — skipping setup" }}
    {{ includeTemplate "log_info" "To install: add kanata-bin to packages.yaml and run chezmoi apply" }}
else
    # Ensure uinput group exists
    {{ includeTemplate "log_step" "Checking uinput group..." }}
    if ! getent group uinput > /dev/null 2>&1; then
        sudo groupadd --system uinput
        {{ includeTemplate "log_success" "uinput group created" }}
    else
        {{ includeTemplate "log_skip" "uinput group already exists" }}
    fi

    # Add user to input and uinput groups (idempotent)
    {{ includeTemplate "log_step" "Checking group membership (input, uinput)..." }}
    for grp in input uinput; do
        if id -nG {{ $username }} | grep -qw "$grp"; then
            {{ includeTemplate "log_skip" "User already in $grp group" }}
        else
            sudo usermod -aG "$grp" {{ $username }}
            {{ includeTemplate "log_success" "User added to $grp group" }}
            {{ includeTemplate "log_warning" "Logout/login required for $grp group change" }}
        fi
    done

    # udev rule for uinput device permissions
    {{ includeTemplate "log_step" "Checking udev rule for uinput..." }}
    UDEV_RULE='KERNEL=="uinput", MODE="0660", GROUP="uinput", OPTIONS+="static_node=uinput"'
    UDEV_FILE="/etc/udev/rules.d/99-uinput.rules"
    if [ -f "$UDEV_FILE" ]; then
        {{ includeTemplate "log_skip" "udev rule already exists" }}
    else
        echo "$UDEV_RULE" | sudo tee "$UDEV_FILE" > /dev/null
        sudo udevadm control --reload-rules
        sudo udevadm trigger
        {{ includeTemplate "log_success" "udev rule created and applied" }}
    fi

    # Load uinput kernel module (persistent)
    # On some kernels uinput is built-in (CONFIG_INPUT_UINPUT=y) and /dev/uinput
    # already exists without any module loading. Only modprobe if the device is absent.
    {{ includeTemplate "log_step" "Checking uinput availability..." }}
    if [ -e /dev/uinput ]; then
        {{ includeTemplate "log_skip" "uinput available (/dev/uinput exists)" }}
    elif lsmod | grep -q uinput; then
        {{ includeTemplate "log_skip" "uinput module already loaded" }}
    else
        if sudo modprobe uinput 2>/dev/null; then
            {{ includeTemplate "log_success" "uinput module loaded" }}
            if [ ! -f /etc/modules-load.d/uinput.conf ]; then
                echo "uinput" | sudo tee /etc/modules-load.d/uinput.conf > /dev/null
                {{ includeTemplate "log_success" "uinput module set to load on boot" }}
            fi
        else
            {{ includeTemplate "log_warning" "Could not load uinput module — /dev/uinput unavailable, kanata will fail to start" }}
        fi
    fi

    # Enable systemd user service (no --now: group changes require logout first)
    {{ includeTemplate "log_step" "Enabling kanata systemd service..." }}
    if systemctl --user is-enabled --quiet kanata 2>/dev/null; then
        {{ includeTemplate "log_skip" "Kanata service already enabled" }}
    else
        systemctl --user enable kanata
        {{ includeTemplate "log_success" "Kanata service enabled" }}
        {{ includeTemplate "log_warning" "Log out and back in, then: systemctl --user start kanata" }}
    fi

    KANATA_CONFIGURED=true
    SERVICES_CONFIGURED=true
fi
{{ else if not (eq .chassisType "laptop") }}
{{ includeTemplate "log_skip" "Kanata setup skipped (desktop — keyboard is hardware-remapped)" }}
{{ else }}
{{ includeTemplate "log_skip" "Kanata setup disabled in features.yaml" }}
{{ end }}

# ============================================================================
# SUMMARY
# ============================================================================

echo ""
echo "════════════════════════════════════════════════════════════════"
echo "  Optional Services Setup Complete"
echo "════════════════════════════════════════════════════════════════"
echo ""

if [ "$VOXTYPE_CONFIGURED" = true ]; then
    echo "  Voxtype Speech-to-Text:"
    echo "    SUPER+T       → Parakeet  (fast English, ONNX CUDA)"
    echo "    SUPER+SHIFT+T → Moonshine (alternate English)"
    echo "    SUPER+CTRL+T  → Whisper   (multilingual)"
    echo "    Text appears in clipboard - paste with Ctrl+V"
    echo "    Engine binary: $(readlink /usr/bin/voxtype 2>/dev/null || echo 'unknown')"
    echo ""
fi

if [ "$BACKUP_CONFIGURED" = true ]; then
    echo "  Home Backup:"
    echo "    Repository: $REPO"
    echo "    Schedule: daily at 2am (home-backup.timer)"
    echo "    Manual run: home-backup backup"
    echo ""
fi

if [ "$KANATA_CONFIGURED" = true ]; then
    echo "  Kanata Keyboard Remapper:"
    echo "    Layout: Workman (ANSI)"
    echo "    Caps Lock → Backspace"
    echo "    Right Meta → live reload config"
    echo "    Config: ~/.config/kanata/kanata.kbd"
    echo "    Service: systemctl --user start kanata  (after logout/login)"
    echo ""
fi

if [ "$SERVICES_CONFIGURED" = false ]; then
    echo "  No optional services configured (packages not installed)"
    echo ""
fi

echo "════════════════════════════════════════════════════════════════"
echo ""

{{ includeTemplate "log_complete" "Optional services setup completed" }}
