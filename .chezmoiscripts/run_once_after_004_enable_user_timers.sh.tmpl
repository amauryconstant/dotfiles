#!/usr/bin/env bash

# Script: run_once_after_004_enable_user_timers.sh.tmpl
# Purpose: Enable and start user systemd timers (wallpaper, health, backup)
# Requirements: Arch Linux, systemd

{{ includeTemplate "log_start" "Setting up user systemd timers" }}

set -euo pipefail

{{ includeTemplate "log_step" "Reloading systemd user daemon" }}
systemctl --user daemon-reload

{{ range .services.user_timers }}
{{ if .enabled }}
# ----------------------------------------------------------------------------
# Timer: {{ .name }}
# ----------------------------------------------------------------------------

{{ includeTemplate "log_step" "Enabling {{ .name }}.timer..." }}

if ! systemctl --user list-unit-files {{ .name }}.timer >/dev/null 2>&1; then
    {{ includeTemplate "log_warning" "{{ .name }}.timer unit file not found — skipping" }}
    {{ includeTemplate "log_info" "Verify: ~/.config/systemd/user/{{ .name }}.* exist" }}
else
    systemctl --user enable {{ .name }}.timer
    {{ if .start }}
    {{ includeTemplate "log_step" "Starting {{ .name }}.timer" }}
    systemctl --user start {{ .name }}.timer

    if systemctl --user is-active --quiet {{ .name }}.timer; then
        {{ includeTemplate "log_success" "{{ .name }}.timer is active" }}
    else
        {{ includeTemplate "log_warning" "{{ .name }}.timer failed to start (check journalctl --user -u {{ .name }}.timer)" }}
    fi
    {{ else }}
    if systemctl --user is-enabled --quiet {{ .name }}.timer; then
        {{ includeTemplate "log_success" "{{ .name }}.timer enabled (not started — needs init first)" }}
        {{ includeTemplate "log_info" "Repository must be initialized first before starting this timer" }}
    else
        {{ includeTemplate "log_warning" "{{ .name }}.timer failed to enable" }}
    fi
    {{ end }}
fi
{{ end }}
{{ end }}

# Trigger initial wallpaper change for wallpaper-cycle after enabling
{{ range .services.user_timers }}{{ if and .enabled (eq .name "wallpaper-cycle") }}
{{ includeTemplate "log_step" "Triggering initial wallpaper change" }}
systemctl --user start wallpaper-cycle.service 2>/dev/null || true
{{ end }}{{ end }}

{{ includeTemplate "log_complete" "User timers configured successfully" }}
